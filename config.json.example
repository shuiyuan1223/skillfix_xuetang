{
  "gateway": {
    "port": 8000,
    "autoStart": false
  },
  "llm": {
    "provider": "openrouter",
    "apiKey": "sk-or-xxx-your-api-key",
    "baseUrl": "https://openrouter.ai/api/v1",
    "modelId": "anthropic/claude-sonnet-4"
  },
  "dataSources": {
    "type": "huawei",
    "huawei": {
      "clientId": "your-huawei-client-id",
      "clientSecret": "your-huawei-client-secret",
      "authUrl": "https://oauth-login.cloud.huawei.com/oauth2/v3/authorize",
      "tokenUrl": "https://oauth-login.cloud.huawei.com/oauth2/v3/token",
      "apiBaseUrl": "https://health-api.cloud.huawei.com"
    }
  },
  "tui": {
    "theme": "dark",
    "showToolCalls": true
  }
}
