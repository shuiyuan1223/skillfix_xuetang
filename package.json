{
  "name": "pha",
  "version": "0.1.0",
  "description": "Personal Health Agent - AI-powered health management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pha": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --outDir dist && bun run build:ui",
    "build:ui": "cd ui && bun install && bun run build",
    "dev": "tsc --outDir dist --watch",
    "dev:ui": "cd ui && bun install && bun run dev",
    "start": "bun ./dist/cli.js start",
    "pha": "bun ./dist/cli.js",
    "check": "tsc --noEmit",
    "lint": "eslint src/ ui/src/",
    "lint:fix": "eslint src/ ui/src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"ui/src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"ui/src/**/*.ts\"",
    "clean": "rm -rf dist ui/dist node_modules",
    "prepare": "husky",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@mariozechner/pi-agent-core": "^0.51.0",
    "@mariozechner/pi-ai": "^0.51.0",
    "@mariozechner/pi-tui": "^0.51.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sinclair/typebox": "^0.34.0",
    "commander": "^14.0.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "health",
    "agent",
    "ai",
    "pha",
    "personal-health-agent"
  ],
  "author": "",
  "license": "MIT"
}
